<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="ScreenProtector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ScreenProtector"
        xmlns:properties="clr-namespace:ScreenProtector.Properties"
                xmlns:loc="clr-namespace:ScreenProtector.Localization"
        mc:Ignorable="d"
        Title="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Title_App]}" Height="600" Width="900"
        Style="{StaticResource DarkWindowStyle}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!-- 主题资源在App.xaml中已加载 -->
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource DarkHeaderStyle}">
            <StackPanel Orientation="Horizontal" Margin="20,16" VerticalAlignment="Center">
                <TextBlock x:Name="IconTextBlock" Text="" FontSize="28" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Title_App]}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Subtitle_App]}" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,0,0">
                                <CheckBox x:Name="StartupCheckBox" Content="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Startup_Enable]}"
                                          VerticalAlignment="Center" Margin="0,0,12,0"
                                          Style="{StaticResource DarkCheckBoxStyle}" IsChecked="True"
                                          Checked="StartupCheckBox_Checked" Unchecked="StartupCheckBox_Unchecked"/>
                                <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Language_SelectLabel]}" 
                                           Style="{StaticResource DarkLabelStyle}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox x:Name="LanguageCombo" Width="120" SelectionChanged="LanguageCombo_SelectionChanged" HorizontalAlignment="Right">
                                </ComboBox>
                        </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,20,20,20">

                 <!-- Brightness Section -->
                 <GroupBox Style="{StaticResource DarkModernGroupBoxStyle}" Header="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Brightness_SectionHeader], StringFormat=🔆 {0}}" Margin="0,0,0,16">
                     <StackPanel>
                         <Grid Margin="0,0,0,16">
                             <Grid.ColumnDefinitions>
                                 <ColumnDefinition Width="*"/>
                                 <ColumnDefinition Width="Auto"/>
                                 <ColumnDefinition Width="Auto"/>
                             </Grid.ColumnDefinitions>
                             <Slider x:Name="BrightnessSlider" Grid.Column="0"
                                     Minimum="0" Maximum="100" 
                                     ValueChanged="BrightnessSlider_ValueChanged" 
                                     TickFrequency="10" IsSnapToTickEnabled="False"
                                     Height="28" VerticalAlignment="Center"/>
                             <TextBlock Grid.Column="1" x:Name="BrightnessLabel" Style="{StaticResource DarkLabelStyle}" Margin="12,0,0,0" MinWidth="40" TextAlignment="Right" FontWeight="SemiBold"> 
                                                                 <TextBlock.Text>
                                                                     {Binding}
                                                                 </TextBlock.Text>
                                                             </TextBlock>
                             <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="12,0,0,0">
                                 <TextBox x:Name="BrightnessInput" Width="50" TextAlignment="Right"
                                          Style="{StaticResource DarkModernTextBoxStyle}"
                                          TextChanged="BrightnessInput_TextChanged" PreviewTextInput="NumberValidation_PreviewTextInput"/>
                                 <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[PercentSign]}" Style="{StaticResource DarkLabelStyle}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                             </StackPanel>
                         </Grid>
                         <Button Content="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Brightness_Refresh], StringFormat=🔄 {0}}" Click="RefreshButton_Click" 
                                 Style="{StaticResource DarkModernButtonStyle}" Width="120" HorizontalAlignment="Left"/>
                     </StackPanel>
                 </GroupBox>

                <!-- Idle Detection Section -->
                <GroupBox Style="{StaticResource DarkModernGroupBoxStyle}" Header="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Idle_SectionHeader], StringFormat=⏱ {0}}" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <CheckBox x:Name="EnableIdleCheck" Content="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Idle_Enable]}"
                                      VerticalAlignment="Center"
                                      Style="{StaticResource DarkCheckBoxStyle}" IsChecked="True"
                                      Checked="EnableIdleCheck_Checked" Unchecked="EnableIdleCheck_Unchecked"/>
                        </StackPanel>

                         <StackPanel Orientation="Horizontal" Margin="0,8,0,16">
                             <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Idle_SecondsLabel]}" Style="{StaticResource DarkLabelStyle}" MinWidth="100"/>
                             <Slider x:Name="IdleSlider" Width="250" 
                                     Minimum="0" Maximum="600" Value="60" 
                                     ValueChanged="IdleSlider_ValueChanged"
                                     Height="28" VerticalAlignment="Center"/>
                             <TextBlock x:Name="IdleLabel" Text="60{x:Static properties:Resources.SecondUnit}" 
                                                                    Style="{StaticResource DarkLabelStyle}" 
                                                                    MinWidth="50" TextAlignment="Right" FontWeight="SemiBold"/>
                             <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                                 <TextBox x:Name="IdleInput" Width="50" TextAlignment="Right"
                                          Style="{StaticResource DarkModernTextBoxStyle}"
                                          TextChanged="IdleInput_TextChanged" PreviewTextInput="NumberValidation_PreviewTextInput"/>
                                 <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[SecondUnit]}" Style="{StaticResource DarkLabelStyle}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                             </StackPanel>
                         </StackPanel>

                        <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Idle_Description]}" 
                                   FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </GroupBox>

                <!-- About Section -->
                <GroupBox Style="{StaticResource DarkModernGroupBoxStyle}" Header="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[About_Header], StringFormat=ℹ {0}}">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[About_Description]}" 
                                   FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[About_Feature1]}" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="12,0,0,8"/>
                        <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[About_Feature2]}" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="12,0,0,8"/>
                        <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[About_Feature3]}" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="12,0,0,0"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Style="{StaticResource DarkFooterStyle}" Padding="20,12">
            <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Footer]}" 
                       FontSize="11" Foreground="{StaticResource SecondaryTextBrush}"/>
        </Border>
    </Grid>
</Window>