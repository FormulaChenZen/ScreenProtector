<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="ScreenProtector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ScreenProtector"
        mc:Ignorable="d"
        Title="Screen Protector" Height="600" Width="900"
        Style="{StaticResource DarkWindowStyle}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!-- 主题资源在App.xaml中已加载 -->
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource DarkHeaderStyle}">
            <StackPanel Orientation="Horizontal" Margin="20,16" VerticalAlignment="Center">
                <TextBlock Text="⚙" FontSize="28" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Screen Protector" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
                    <TextBlock Text="Brightness Control &amp; Idle Detection" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,0,0">
                    <CheckBox x:Name="StartupCheckBox" Content="开机启动"
                              VerticalAlignment="Center" Margin="0,0,20,0"
                              Style="{StaticResource DarkCheckBoxStyle}"
                              Checked="StartupCheckBox_Checked" Unchecked="StartupCheckBox_Unchecked"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,20,20,20">

                 <!-- Brightness Section -->
                 <GroupBox Style="{StaticResource DarkModernGroupBoxStyle}" Header="🔆 屏幕亮度" Margin="0,0,0,16">
                     <StackPanel>
                         <Grid Margin="0,0,0,16">
                             <Grid.ColumnDefinitions>
                                 <ColumnDefinition Width="*"/>
                                 <ColumnDefinition Width="Auto"/>
                                 <ColumnDefinition Width="Auto"/>
                             </Grid.ColumnDefinitions>
                             <Slider x:Name="BrightnessSlider" Grid.Column="0"
                                     Minimum="0" Maximum="100" 
                                     ValueChanged="BrightnessSlider_ValueChanged" 
                                     TickFrequency="10" IsSnapToTickEnabled="False"
                                     Height="28" VerticalAlignment="Center"/>
                             <TextBlock Grid.Column="1" x:Name="BrightnessLabel" Text="--%"
                                        Style="{StaticResource DarkLabelStyle}" Margin="12,0,0,0" 
                                        MinWidth="40" TextAlignment="Right" FontWeight="SemiBold"/>
                             <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="12,0,0,0">
                                 <TextBox x:Name="BrightnessInput" Width="50" TextAlignment="Right"
                                          Style="{StaticResource DarkModernTextBoxStyle}"
                                          TextChanged="BrightnessInput_TextChanged" PreviewTextInput="NumberValidation_PreviewTextInput"/>
                                 <TextBlock Text="%" Style="{StaticResource DarkLabelStyle}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                             </StackPanel>
                         </Grid>
                         <Button Content="🔄 刷新当前亮度" Click="RefreshButton_Click" 
                                 Style="{StaticResource DarkModernButtonStyle}" Width="120" HorizontalAlignment="Left"/>
                     </StackPanel>
                 </GroupBox>

                <!-- Idle Detection Section -->
                <GroupBox Style="{StaticResource DarkModernGroupBoxStyle}" Header="⏱ 静置自动降亮" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <CheckBox x:Name="EnableIdleCheck" Content="启用静置自动降亮"
                                      VerticalAlignment="Center"
                                      Style="{StaticResource DarkCheckBoxStyle}"
                                      Checked="EnableIdleCheck_Checked" Unchecked="EnableIdleCheck_Unchecked"/>
                        </StackPanel>

                         <StackPanel Orientation="Horizontal" Margin="0,8,0,16">
                             <TextBlock Text="静置时长 (秒):" Style="{StaticResource DarkLabelStyle}" MinWidth="100"/>
                             <Slider x:Name="IdleSlider" Width="250" 
                                     Minimum="0" Maximum="600" Value="60" 
                                     ValueChanged="IdleSlider_ValueChanged"
                                     Height="28" VerticalAlignment="Center"/>
                             <TextBlock x:Name="IdleLabel" Text="60s" 
                                        Style="{StaticResource DarkLabelStyle}" 
                                        MinWidth="50" TextAlignment="Right" FontWeight="SemiBold"/>
                             <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                                 <TextBox x:Name="IdleInput" Width="50" TextAlignment="Right"
                                          Style="{StaticResource DarkModernTextBoxStyle}"
                                          TextChanged="IdleInput_TextChanged" PreviewTextInput="NumberValidation_PreviewTextInput"/>
                                 <TextBlock Text="s" Style="{StaticResource DarkLabelStyle}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                             </StackPanel>
                         </StackPanel>

                        <TextBlock Text="当电脑静置达到设定时间后，屏幕亮度将自动降至最低。恢复操作后，亮度将恢复到之前的设置。" 
                                   FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </GroupBox>

                <!-- About Section -->
                <GroupBox Style="{StaticResource DarkModernGroupBoxStyle}" Header="ℹ 关于">
                    <StackPanel>
                        <TextBlock Text="Screen Protector 是一款屏幕保护应用，支持：" 
                                   FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="✓ 实时亮度调节" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="12,0,0,8"/>
                        <TextBlock Text="✓ 静置自动降亮以保护眼睛" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="12,0,0,8"/>
                        <TextBlock Text="✓ 开机自启动功能" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="12,0,0,0"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Style="{StaticResource DarkFooterStyle}" Padding="20,12">
            <TextBlock Text="© 2024 Screen Protector | 帮助保护您的视力和屏幕" 
                       FontSize="11" Foreground="{StaticResource SecondaryTextBrush}"/>
        </Border>
    </Grid>
</Window>