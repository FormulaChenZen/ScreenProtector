<ui:FluentWindow x:Class="ScreenProtector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:ScreenProtector"
        xmlns:loc="clr-namespace:ScreenProtector.Localization"
        mc:Ignorable="d"
        Title="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Title_App]}"
        Height="640" Width="880"
        MinHeight="520" MinWidth="640"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Grid.Row="0" Title="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Title_App]}">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                    <ui:SymbolIcon Symbol="BrightnessHigh24" FontSize="20" Margin="0,0,8,0" Opacity="0.8"/>
                    <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Subtitle_App]}"
                               FontSize="12" Opacity="0.6" VerticalAlignment="Center"/>
                </StackPanel>
            </ui:TitleBar.Header>
            <ui:TitleBar.TrailingContent>
                <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                    <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Language_SelectLabel]}"
                               FontSize="12" Opacity="0.6" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="LanguageCombo" Width="110"
                              SelectionChanged="LanguageCombo_SelectionChanged"/>
                </StackPanel>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" Padding="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="36,8,36,24">

                <!-- Brightness Section -->
                <ui:Card Margin="0,0,0,12" Padding="24,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <ui:SymbolIcon Symbol="BrightnessHigh24" FontSize="20" Opacity="0.8" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Brightness_SectionHeader]}"
                                       FontSize="16" FontWeight="SemiBold"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="BrightnessSlider" Grid.Column="0"
                                    Minimum="0" Maximum="100"
                                    ValueChanged="BrightnessSlider_ValueChanged"
                                    TickFrequency="10" IsSnapToTickEnabled="False"
                                    Height="28" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="BrightnessLabel"
                                       FontSize="16" FontWeight="SemiBold" MinWidth="44"
                                       TextAlignment="Right" VerticalAlignment="Center" Margin="14,0,0,0"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                                <ui:TextBox x:Name="BrightnessInput" Width="56" TextAlignment="Center"
                                            TextChanged="BrightnessInput_TextChanged"
                                            PreviewTextInput="NumberValidation_PreviewTextInput"/>
                                <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[PercentSign]}"
                                           FontSize="13" Opacity="0.6" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Grid>

                        <ui:Button Appearance="Secondary"
                                   Content="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Brightness_Refresh]}"
                                   Click="RefreshButton_Click"
                                   HorizontalAlignment="Left"
                                   Icon="{ui:SymbolIcon ArrowSync16}"/>
                    </StackPanel>
                </ui:Card>

                <!-- Idle Detection Section -->
                <ui:Card Margin="0,0,0,12" Padding="24,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <ui:SymbolIcon Symbol="Clock32" FontSize="20" Opacity="0.8" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Idle_SectionHeader]}"
                                       FontSize="16" FontWeight="SemiBold"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Idle_Enable]}"
                                       FontSize="14" VerticalAlignment="Center"/>
                            <ui:ToggleSwitch x:Name="EnableIdleCheck" Grid.Column="1"
                                             IsChecked="True"
                                             Checked="EnableIdleCheck_Checked"
                                             Unchecked="EnableIdleCheck_Unchecked"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Idle_SecondsLabel]}"
                                       FontSize="13" MinWidth="100" VerticalAlignment="Center"/>
                            <Slider x:Name="IdleSlider" Width="240"
                                    Minimum="0" Maximum="600" Value="60"
                                    ValueChanged="IdleSlider_ValueChanged"
                                    Height="28" VerticalAlignment="Center"/>
                            <TextBlock x:Name="IdleLabel" Text="60"
                                       FontSize="16" FontWeight="SemiBold"
                                       MinWidth="44" TextAlignment="Right" VerticalAlignment="Center" Margin="14,0,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                                <ui:TextBox x:Name="IdleInput" Width="56" TextAlignment="Center"
                                            TextChanged="IdleInput_TextChanged"
                                            PreviewTextInput="NumberValidation_PreviewTextInput"/>
                                <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[SecondUnit]}"
                                           FontSize="13" Opacity="0.6" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Idle_Description]}"
                                   FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                    </StackPanel>
                </ui:Card>

                <!-- Startup Section -->
                <ui:Card Margin="0,0,0,12" Padding="24,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="PlugConnected24" FontSize="20" Opacity="0.8" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Startup_Enable]}"
                                       FontSize="14"/>
                        </StackPanel>
                        <ui:ToggleSwitch x:Name="StartupCheckBox" Grid.Column="1"
                                         IsChecked="True"
                                         Checked="StartupCheckBox_Checked"
                                         Unchecked="StartupCheckBox_Unchecked"/>
                    </Grid>
                </ui:Card>

                <!-- About Section -->
                <ui:Card Margin="0,0,0,0" Padding="24,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <ui:SymbolIcon Symbol="Info12" FontSize="20" Opacity="0.8" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[About_Header]}"
                                       FontSize="16" FontWeight="SemiBold"/>
                        </StackPanel>

                        <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[About_Description]}"
                                   FontSize="12" Opacity="0.6" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[About_Feature1]}"
                                   FontSize="12" Opacity="0.6" Margin="12,0,0,8"/>
                        <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[About_Feature2]}"
                                   FontSize="12" Opacity="0.6" Margin="12,0,0,8"/>
                        <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[About_Feature3]}"
                                   FontSize="12" Opacity="0.6" Margin="12,0,0,16"/>

                        <Separator Margin="0,0,0,12" Opacity="0.2"/>
                        <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Website_Label]}"
                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Website_Description]}"
                                   FontSize="12" Opacity="0.5" Margin="0,0,0,8"/>

                        <ui:Button Appearance="Transparent" Click="WebsiteButton_Click"
                                   HorizontalAlignment="Left"
                                   Icon="{ui:SymbolIcon Link12}">
                            <TextBlock Text="Rumystic.com" FontSize="12"/>
                        </ui:Button>
                    </StackPanel>
                </ui:Card>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="36,10" Opacity="0.4">
            <TextBlock Text="{Binding Source={x:Static loc:TranslationProvider.Instance}, Path=[Footer]}"
                       FontSize="11"/>
        </Border>
    </Grid>
</ui:FluentWindow>
